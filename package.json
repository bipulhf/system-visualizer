{
  "name": "system-visualizer",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun --filter @visualizer/web dev",
    "dev:server": "bun --filter @visualizer/server dev",
    "build": "bun run build:shared && bun run build:server && bun run build:web",
    "build:web": "bun --filter @visualizer/web build",
    "build:server": "bun --filter @visualizer/server build",
    "build:shared": "bun --filter @visualizer/shared build",
    "typecheck": "bun run typecheck:shared && bun run typecheck:server && bun run typecheck:web",
    "typecheck:web": "bun --filter @visualizer/web typecheck",
    "typecheck:server": "bun --filter @visualizer/server typecheck",
    "typecheck:shared": "bun --filter @visualizer/shared typecheck"
  }
}
